<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.HomeController">
    <top>

        <VBox alignment="CENTER" spacing="10">

            <Label text="Cidade Melhor"
                   styleClass="title"/>

            <Label text="Sistema de Reclamações Urbanas"
                   styleClass="subtitle" />

            <HBox alignment="CENTER" spacing="20">

                <Button text="Nova Reclamação"
                        onAction="#newComplaint"
                        styleClass="main-button"/>

                <Button text="Ver Reclamações"
                        onAction="#seeComplaints"
                        styleClass="main-button"/>

            </HBox>

        </VBox>

    </top>

    <center>

        <StackPane fx:id="contentArea"/>

    </center>

</BorderPane>