<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.HomeController">

    <top>

        <VBox alignment="CENTER" spacing="10">

            <Label text="Cidade Melhor"
                   style="-fx-font-size: 36px; -fx-font-weight: bold;" />

            <Label text="Sistema de Reclamações Urbanas"
                   style="-fx-font-size: 18px;" />

            <HBox alignment="CENTER" spacing="20">

                <Button text="Nova Reclamação"
                        onAction="#newComplaint"/>

                <Button text="Ver Reclamações"
                        onAction="#seeComplaints"/>

            </HBox>

        </VBox>

    </top>

    <center>

        <StackPane fx:id="contentArea"/>

    </center>

</BorderPane>