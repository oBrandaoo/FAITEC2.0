<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.HomeController">


    <!-- TOPBAR -->
    <top>

        <HBox alignment="CENTER_LEFT"
              spacing="40"
              style="-fx-padding: 15; -fx-background-color: #ecf0f1;">

            <!-- LOGO / NOME -->
            <Label text="Cidade Melhor"
                   style="-fx-font-size: 22px; -fx-font-weight: bold;" />

            <!-- MENU -->
            <HBox spacing="20">

                <Button text="🏠 Início"
                        fx:id="Inicio"
                        styleClass="botaoInicio"
                        onAction="#goHome"/>


                <Button text="📝 Nova Reclamação"
                        fx:id="Reclamaçao"
                        styleClass="botaoReclamaçao"
                        onAction="#newComplaint"/>

                <Button text="📋 Reclamações"
                        fx:id="Reclamaçoes"
                        styleClass="botaoReclamaçoes"
                        onAction="#seeComplaints"/>

            </HBox>

        </HBox>

    </top>

    <!-- CONTEÚDO -->
    <center>
        <StackPane fx:id="contentArea"
                   style="-fx-padding: 30;" />

    </center>

</BorderPane>