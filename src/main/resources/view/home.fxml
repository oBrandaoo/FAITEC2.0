<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.HomeController">


    <!-- TOPBAR -->
    <top>

        <HBox alignment="CENTER_LEFT"
              spacing="40"
              style="-fx-padding: 15; -fx-background-color: #ecf0f1;">

            <!-- LOGO / NOME -->
            <Label text="Cidade Melhor"
                   styleClass="logo" />

            <!-- MENU -->
            <HBox spacing="20">

                <Button text="🏠 Início"
                        fx:id="Inicio"
                        styleClass="botaoInicio"
                        onAction="#goHome"/>


                <Button text="📝 Nova Reclamação"
                        fx:id="Reclamacao"
                        styleClass="botaoReclamacao"
                        onAction="#newComplaint"/>

                <Button text="📋 Reclamações"
                        fx:id="Reclamacoes"
                        styleClass="botaoReclamacoes"
                        onAction="#seeComplaints"/>

            </HBox>

        </HBox>

    </top>

    <!-- CONTEÚDO -->
    <center>
        <StackPane fx:id="contentArea"
                   style="-fx-padding: 30;" />

    </center>

</BorderPane>